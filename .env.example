# ── Credenciales de Twitch ──────────────────────────────────────────────────
# Obtenidas desde twitchtokengenerator.com con tu app de dev.twitch.tv
TWITCH_CLIENT_ID=tu_client_id_aqui
TWITCH_CLIENT_SECRET=tu_client_secret_aqui
TWITCH_ACCESS_TOKEN=tu_access_token_aqui
TWITCH_REFRESH_TOKEN=tu_refresh_token_aqui

# Nombre de usuario de la cuenta del bot en Twitch
TWITCH_BOT_NICK=NombreDeTuBotEnTwitch

# Canal de Twitch a escuchar (sin el #)
TWITCH_CHANNEL=nombre_del_canal_a_escuchar

# ── Servidor Archipelago ────────────────────────────────────────────────────
AP_HOST=archipelago.gg
AP_PORT=12345
AP_PASSWORD=
# Nombre con el que el bot se une al servidor de Archipelago
AP_BOT_NAME=TwitchipelagoBot
# Jugador de Archipelago vinculado a este canal de Twitch
AP_PLAYER_NAME=NombreDelJugadorEnAP

# ── Recompensas ─────────────────────────────────────────────────────────────
# Cantidad de bits necesaria para activar un hint aleatorio
BITS_FOR_HINT=200
# Cooldown en segundos entre hints del mismo canal (300 = 5 minutos)
HINT_COOLDOWN_SECONDS=0
